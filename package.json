{
  "name": "serverless-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Serverless AI agent runtime for chat workspaces on AWS and Amazon Bedrock AgentCore",
  "scripts": {
    "generate-skills": "ts-node scripts/generate-builtin-skills.ts",
    "prebuild": "npm run generate-skills",
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run generate-skills",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pretypecheck": "npm run generate-skills",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "import-local-docs": "ts-node scripts/import-local-docs.ts",
    "ingest-markdown": "ts-node scripts/ingest-markdown.ts",
    "extract-pdf-markdown": "ts-node scripts/extract-pdf-markdown.ts",
    "put-provider-binding": "ts-node scripts/put-provider-binding.ts",
    "ask-agent": "ts-node scripts/ask-agent.ts",
    "dev:chat": "ts-node scripts/dev-chat.ts"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.0",
    "@aws-crypto/sha256-js": "5.2.0",
    "@aws-sdk/client-bedrock-agentcore": "^3.996.0",
    "@aws-sdk/client-dynamodb": "3.1029.0",
    "@aws-sdk/client-s3": "3.1029.0",
    "@aws-sdk/client-scheduler": "3.1029.0",
    "@aws-sdk/client-sqs": "3.1029.0",
    "@aws-sdk/client-ssm": "3.1029.0",
    "@aws-sdk/credential-provider-node": "3.972.31",
    "@aws-sdk/lib-dynamodb": "3.1029.0",
    "@aws-sdk/s3-request-presigner": "3.1029.0",
    "@aws/agentcore-cdk": "^0.1.0-alpha.19",
    "@mozilla/readability": "^0.6.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@smithy/protocol-http": "5.3.14",
    "@smithy/signature-v4": "5.3.14",
    "ai": "^6.0.0",
    "aws-cdk-lib": "2.248.0",
    "bedrock-agentcore": "^0.2.3",
    "constructs": "10.6.0",
    "dotenv": "^17.4.2",
    "jimp": "^1.6.1",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.60.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/jsdom": "^28.0.3",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "^4.1.6",
    "aws-cdk": "2.1118.0",
    "esbuild": "0.28.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.2",
    "vitest": "^4.1.6"
  }
}
